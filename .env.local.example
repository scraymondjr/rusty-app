# ── Firebase client SDK (safe to expose in browser) ──────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side only — NEVER expose to client) ────────────
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the JSON values here individually.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key exactly as shown in the JSON file.
# The literal \n characters in the key are preserved — the server replaces them at runtime.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Owner email — seeded manually in Firestore access collection
OWNER_EMAIL=

# ── Resend (invite emails) ────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender address in your Resend account (e.g. rusty@rusty.scrjr.com)
RESEND_FROM=Rusty <rusty@rusty.scrjr.com>

# ── Anthropic (Phase 5 — AI ingestion) ───────────────────────────────────────
# ANTHROPIC_API_KEY=
