rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public photos are readable by anyone
    match /dogs/{dogId}/photos/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // All other dog files require authentication
    match /dogs/{dogId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
