rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // All writes go through /api/upload, which uses the Admin SDK and enforces
    // role checks server-side. Deny direct client-SDK writes from every role.

    // Photos may be public (needed for Phase 4 public landing page)
    match /dogs/{dogId}/photos/{allPaths=**} {
      allow read:  if true;
      allow write: if false;
    }

    // All other dog files require authentication to read
    match /dogs/{dogId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
